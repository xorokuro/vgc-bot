# Copy this file to .env and fill in your values

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your application's Client ID (found on the OAuth2 or General Information page)
CLIENT_ID=your_application_client_id_here

# Guild (server) ID for instant command registration during development
# Remove or leave blank to register commands globally (takes up to 1 hour)
GUILD_ID=your_test_guild_id_here
